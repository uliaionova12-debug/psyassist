# QA / founder bypass
# - NEXT_PUBLIC_FOUNDER_MODE enables QA mode for this browser (client-visible).
# - FOUNDER_EMAIL enables QA mode for an authenticated user on the server.
# - Additionally, you can enable QA mode per-session with `?qa=true`.
NEXT_PUBLIC_FOUNDER_MODE="false"
# Tension interrupt in question_flow (stop + probe + working hypothesis). Off for production beta unless enabled.
NEXT_PUBLIC_TENSION_INTERRUPT_ENABLED="false"
FOUNDER_EMAIL="founder@example.com"
# Optional UUID for founder account (used with reset endpoint + service role lookup).
# FOUNDER_USER_ID=

# One-time QA reset of free intro in DB: POST /api/dev/reset-founder-intro with
# Authorization: Bearer <secret> or x-founder-reset-secret: <secret>
# FOUNDER_QA_RESET_SECRET=
# (alias) DEV_FOUNDER_RESET_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: только на сервере (вебхуки, админ). Никогда в клиентском бандле.
SUPABASE_SERVICE_ROLE_KEY=


# В Supabase Auth → URL Configuration: Site URL и Redirect URLs должны включать
# {NEXT_PUBLIC_APP_URL}/auth/callback (для magic link / OAuth).

# ЮKassa (оплата): shop id и секрет из личного кабинета; публичный base URL для return_url (приоритет над NEXT_PUBLIC_APP_URL на сервере)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Необязательно: если задан, вебхук требует Authorization: Basic base64(SHOP_ID:SECRET)
# (секрет может совпадать с YOOKASSA_SECRET_KEY или быть отдельным паролем из кабинета).
YOOKASSA_WEBHOOK_SECRET=
YOOKASSA_RETURN_URL=
NEXT_PUBLIC_APP_URL=

# ── Google Gemini (супервизионный разбор, только на сервере) ────────────────
# Ключ API: https://aistudio.google.com/apikey  (или Google AI Studio → Get API key)
GEMINI_API_KEY=
# Необязательно; по умолчанию gemini-2.5-flash (см. src/lib/ai/gemini-clinical.ts)
# GEMINI_MODEL=gemini-2.5-flash
# Если используете свой прокси к Gemini (редко):
# AI_INTEGRATIONS_GEMINI_BASE_URL=
# AI_INTEGRATIONS_GEMINI_API_KEY=

